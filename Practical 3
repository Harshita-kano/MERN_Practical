  const totalLec = 60;
  const attendance = (lecAttend/totalLec)*100;
  return(
    <div>
      <h1>Student Details</h1>
      <p>Name : {stu}</p>
      <p>Department : {dept}</p>
      <p>Total Lectures Attended : {lecAttend}</p>
      <p>Total Number of Lectures : {totalLec}</p>
      <p>Student Attendance : {attendance.toFixed(2)}%</p>
      <hr></hr>
      <h2> Eligiblity Status : {attendance >= 75?"Eligible for Exams" : "Not Eligible for Exams"} </h2>
      <hr></hr>
    </div>
  );
}
